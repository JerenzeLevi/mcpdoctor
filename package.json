{
  "name": "mcpdoctor",
  "version": "0.1.0",
  "description": "Diagnose your MCP (Model Context Protocol) server configs: discover, connect, and flag misconfigurations.",
  "type": "module",
  "bin": {
    "mcpdoctor": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "diagnostics",
    "claude"
  ],
  "homepage": "https://github.com/JerenzeLevi/mcpdoctor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JerenzeLevi/mcpdoctor.git"
  },
  "bugs": {
    "url": "https://github.com/JerenzeLevi/mcpdoctor/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "jsonc-parser": "^3.3.1",
    "ora": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  }
}
